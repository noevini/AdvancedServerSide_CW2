<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>Verify Email — Alumni Analytics</title>
</head>
<body class="login-page">

  <div class="login-container">

    <div class="login-header">
      <h1>🎓 Alumni Analytics</h1>
      <p>Verify your email address</p>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <% if (token) { %>
      <div class="alert" style="background:#f0fdf4;color:#166534;border:1px solid #bbf7d0;margin-bottom:1rem;font-size:0.9rem;">
        Your verification code is: <strong style="font-size:1.1rem;letter-spacing:0.1em;"><%= token %></strong>
        <br/><small style="opacity:0.75;">(In production this would be sent to your email)</small>
      </div>
    <% } %>

    <form action="/verify-email" method="POST" class="login-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

      <div class="form-group">
        <label for="token">Verification Code</label>
        <input type="text" id="token" name="token" placeholder="Enter code" required autocomplete="one-time-code" style="letter-spacing:0.15em;text-transform:uppercase;" />
      </div>

      <button type="submit" class="btn-login">Verify Email</button>
    </form>

  </div>

</body>
</html>
