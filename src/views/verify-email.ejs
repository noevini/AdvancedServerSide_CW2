<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>Verify Email — Alumni Analytics</title>
</head>
<body class="login-page">

  <div class="login-container">

    <div class="login-header">
      <h1>🎓 Alumni Analytics</h1>
      <p>Verify your email address</p>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <% if (success) { %>
      <div class="alert" style="background:#f0fdf4;color:#166534;border:1px solid #bbf7d0;margin-bottom:1rem;font-size:0.9rem;">
        <%= success %>
        <br/><a href="/login" style="color:#166534;font-weight:600;">Return to login</a>
      </div>
    <% } else { %>

    <p style="margin-bottom:1rem;font-size:0.9rem;color:#555;">Click the button below to verify your email address.</p>

    <form action="/verify-email" method="POST" class="login-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <button type="submit" class="btn-login">Verify Email</button>
    </form>

    <% } %>

  </div>

</body>
</html>
