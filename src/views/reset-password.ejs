<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>Reset Password — Alumni Analytics</title>
</head>
<body class="login-page">

  <div class="login-container">

    <div class="login-header">
      <h1>🎓 Alumni Analytics</h1>
      <p>Reset your password</p>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <% if (success) { %>
      <div class="alert" style="background:#f0fdf4;color:#166534;border:1px solid #bbf7d0;margin-bottom:1rem;font-size:0.9rem;">
        <%= success %>
      </div>
    <% } %>

    <% if (typeof resetToken !== 'undefined' && resetToken) { %>
      <div class="alert" style="background:#fffbeb;color:#92400e;border:1px solid #fde68a;margin-bottom:1rem;font-size:0.9rem;">
        Your reset code is: <strong style="font-size:1.1rem;letter-spacing:0.1em;"><%= resetToken %></strong>
        <br/><small style="opacity:0.75;">(In production this would be sent to your email)</small>
      </div>
    <% } %>

    <% if (stage === 'request') { %>
      <form action="/reset-password" method="POST" class="login-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="stage" value="request" />

        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="your@university.ac.uk" required autocomplete="email" />
        </div>

        <button type="submit" class="btn-login">Send Reset Code</button>
      </form>

    <% } else if (stage === 'confirm') { %>
      <form action="/reset-password" method="POST" class="login-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="stage" value="confirm" />

        <div class="form-group">
          <label for="token">Reset Code</label>
          <input type="text" id="token" name="token" placeholder="Enter code" required style="letter-spacing:0.15em;text-transform:uppercase;" />
        </div>

        <div class="form-group">
          <label for="password">New Password</label>
          <input type="password" id="password" name="password" placeholder="Min. 8 characters" required autocomplete="new-password" />
        </div>

        <button type="submit" class="btn-login">Set New Password</button>
      </form>

    <% } else if (stage === 'done') { %>
      <p style="text-align:center;margin-top:0.5rem;">
        <a href="/login" style="color:#c8102e;font-weight:600;">Back to Login</a>
      </p>
    <% } %>

    <% if (stage !== 'done') { %>
      <p style="text-align:center;margin-top:1rem;font-size:0.85rem;color:#666;">
        <a href="/login" style="color:#c8102e;font-weight:600;">Back to Login</a>
      </p>
    <% } %>

  </div>

</body>
</html>
