<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>Dashboard — Alumni Analytics</title>
</head>
<body>

  <%- include('partials/navbar', { page: 'dashboard' }) %>

  <main class="main-content">

    <!-- Page header -->
    <div class="page-header">
      <h1>Computer Science Programme Analytics</h1>
      <p>Graduate Outcomes & Skills Gap Intelligence Dashboard</p>
    </div>

    <!-- Error banner (shown if API is unreachable) -->
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <!-- Summary stat cards -->
    <% if (summary) { %>
    <div class="stats-grid">

      <div class="stat-card">
        <span class="stat-label">TOTAL ALUMNI TRACKED</span>
        <span class="stat-value"><%= summary.totalAlumni %></span>
        <span class="stat-sub positive">↑ from last year</span>
      </div>

      <div class="stat-card">
        <span class="stat-label">EMPLOYMENT RATE</span>
        <span class="stat-value"><%= summary.employmentRate %>%</span>
        <span class="stat-sub positive">↑ from 2024 cohort</span>
      </div>

    </div>
    <% } %>

    <!-- Skills Gap chart preview -->
    <% if (certifications) { %>
    <div class="chart-section">
      <h2>Skills Gap Analysis</h2>
      <p class="chart-desc">Certifications acquired post-graduation reveal curriculum deficiencies</p>

      <div class="chart-card">
        <h3>Top 10 Post-Graduation Certifications</h3>
        <p class="chart-desc">Red = critical gap (>70%) | Amber = significant (50-70%) | Orange = emerging (30-50%)</p>
        <canvas id="certificationsChart"></canvas>
      </div>
    </div>
    <% } %>

  </main>

  <%- include('partials/footer') %>

  <!-- Chart.js from CDN -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <!-- Pass EJS data to client-side JS as a JSON object -->
  <script>
    const certData = JSON.parse('<%- JSON.stringify(certifications || null) %>');
  </script>

  <!-- Dashboard charts script -->
  <script src="/js/dashboard.js"></script>

</body>
</html>