<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>Graphs — Alumni Analytics</title>
</head>
<body>

  <%- include('partials/navbar', { page: 'graphs' }) %>

  <main class="main-content">

    <!-- Page header -->
    <div class="page-header">
      <h1>Data Visualisation</h1>
      <p>Interactive charts showing graduate outcomes and skills trends</p>
    </div>

    <!-- Error banner -->
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <!-- Graph filters -->
    <form method="GET" action="/graphs" class="filters" id="graphFilters">
      <select name="programme" class="filter-select" onchange="document.getElementById('graphFilters').submit()">
        <option value="">All Programmes</option>
        <option value="BSc Computer Science"    <%= filters.programme === 'BSc Computer Science'    ? 'selected' : '' %>>BSc Computer Science</option>
        <option value="BSc Data Science"        <%= filters.programme === 'BSc Data Science'        ? 'selected' : '' %>>BSc Data Science</option>
        <option value="BSc Cybersecurity"       <%= filters.programme === 'BSc Cybersecurity'       ? 'selected' : '' %>>BSc Cybersecurity</option>
        <option value="BSc Software Engineering"<%= filters.programme === 'BSc Software Engineering'? 'selected' : '' %>>BSc Software Engineering</option>
        <option value="BSc AI"                  <%= filters.programme === 'BSc AI'                  ? 'selected' : '' %>>BSc AI</option>
      </select>
      <select name="year" class="filter-select" onchange="document.getElementById('graphFilters').submit()">
        <option value="">All Years</option>
        <% ['2019','2020','2021','2022','2023','2024'].forEach(function(y) { %>
          <option value="<%= y %>" <%= filters.year === y ? 'selected' : '' %>><%= y %></option>
        <% }) %>
      </select>
      <% if (filters.programme || filters.year) { %>
        <a href="/graphs" class="btn-clear" style="text-decoration:none;display:inline-flex;align-items:center;">Clear</a>
      <% } %>
    </form>

    <!-- Skills Gap — Bar chart -->
    <div class="chart-section">
      <h2>Skills Gap Analysis</h2>
      <p class="chart-desc">Certifications acquired post-graduation reveal curriculum deficiencies</p>
      <div class="chart-card">
        <h3>Top 10 Post-Graduation Certifications</h3>
        <div class="chart-loading" id="loading-certificationsChart"></div>
        <canvas id="certificationsChart" style="display:none"></canvas>
        <button class="btn-download" onclick="downloadChart('certificationsChart', 'certifications')">Download</button>
      </div>
    </div>

    <!-- Trends — Line chart -->
    <div class="chart-section">
      <h2>Emerging Technology Adoption Trends</h2>
      <p class="chart-desc">Certification growth over graduation years</p>
      <div class="chart-card">
        <div class="chart-loading" id="loading-trendsChart"></div>
        <canvas id="trendsChart" style="display:none"></canvas>
        <button class="btn-download" onclick="downloadChart('trendsChart', 'trends')">Download</button>
      </div>
    </div>

    <!-- Employment — Pie + Doughnut side by side -->
    <div class="chart-section">
      <h2>Graduate Outcomes Analysis</h2>
      <p class="chart-desc">Where our graduates work and what roles they hold</p>
      <div class="charts-row">
        <div class="chart-card">
          <h3>Employment by Industry Sector</h3>
          <div class="chart-loading" id="loading-industryChart"></div>
          <canvas id="industryChart" style="display:none"></canvas>
          <button class="btn-download" onclick="downloadChart('industryChart', 'industry')">Download</button>
        </div>
        <div class="chart-card">
          <h3>Most Common Job Titles</h3>
          <div class="chart-loading" id="loading-jobTitlesChart"></div>
          <canvas id="jobTitlesChart" style="display:none"></canvas>
          <button class="btn-download" onclick="downloadChart('jobTitlesChart', 'job-titles')">Download</button>
        </div>
      </div>
    </div>

    <!-- Top Employers — Horizontal bar chart -->
    <div class="chart-section">
      <h2>Top Employers</h2>
      <p class="chart-desc">Organisations employing the most graduates</p>
      <div class="chart-card">
        <div class="chart-loading" id="loading-employersChart"></div>
        <canvas id="employersChart" style="display:none"></canvas>
        <button class="btn-download" onclick="downloadChart('employersChart', 'employers')">Download</button>
      </div>
    </div>

    <!-- Short Courses — Radar chart -->
    <div class="chart-section">
      <h2>Post-Graduation Course Categories</h2>
      <p class="chart-desc">Distribution of short courses completed after graduation</p>
      <div class="chart-card">
        <div class="chart-loading" id="loading-coursesChart"></div>
        <canvas id="coursesChart" style="display:none"></canvas>
        <button class="btn-download" onclick="downloadChart('coursesChart', 'courses')">Download</button>
      </div>
    </div>

    <!-- Geographic Distribution — Radar chart -->
    <div class="chart-section">
      <h2>Geographic Distribution</h2>
      <p class="chart-desc">Cities where graduates are currently employed</p>
      <div class="chart-card">
        <div class="chart-loading" id="loading-geographicChart"></div>
        <canvas id="geographicChart" style="display:none"></canvas>
        <button class="btn-download" onclick="downloadChart('geographicChart', 'geographic')">Download</button>
      </div>
    </div>

  </main>

  <%- include('partials/footer') %>

  <!-- Chart.js from CDN -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <!-- Pass EJS data to client-side JS as JSON objects -->
<script>
  const certData = JSON.parse('<%- JSON.stringify(certifications || {"labels":[],"values":[]}) %>');
  const trendsData = JSON.parse('<%- JSON.stringify(trends || {"labels":[],"datasets":[]}) %>');
  const employmentData = JSON.parse('<%- JSON.stringify(employment || {"industries":{"labels":[],"values":[]},"jobTitles":{"labels":[],"values":[]},"employers":{"labels":[],"values":[]}}) %>');
  const coursesData = JSON.parse('<%- JSON.stringify(courses || {"labels":[],"values":[]}) %>');
  const geoData = JSON.parse('<%- JSON.stringify(geographic || {"labels":[],"values":[]}) %>');
</script>

  <!-- Graphs charts script -->
  <script src="/js/graphs.js"></script>

</body>
</html>
